---
import { ArrowDown, BriefcaseBusiness, CodeXml, Download, Mail, Phone } from "@lucide/astro";
---

<section id="top" class="relative min-h-[760px] overflow-hidden pt-16">
  <img
    src="/images/hero-architecture.png"
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-55"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,var(--bg)_0%,color-mix(in_srgb,var(--bg)_78%,transparent)_42%,color-mix(in_srgb,var(--bg)_30%,transparent)_100%)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[color:var(--bg)] to-transparent"></div>

  <div class="container relative z-10 grid min-h-[690px] items-center gap-12 py-16 lg:grid-cols-[1.08fr_0.92fr]">
    <div class="max-w-4xl reveal">
      <p class="eyebrow">Technical Lead / Principal Engineer</p>
      <h1 class="mt-5 font-display text-5xl font-extrabold leading-[1.02] tracking-normal text-[color:var(--text)] md:text-7xl">
        Vinay Reddy
      </h1>
      <p class="mt-5 max-w-3xl text-xl font-semibold leading-8 text-[color:var(--text)] md:text-2xl">
        Technical Lead | Mobile Engineering | Full Stack | Applied AI / GenAI | Product Engineering
      </p>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">
        Building scalable mobile, full-stack, and AI-powered products across healthcare, banking security, mobility, SaaS, IoT, and enterprise domains.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="button button-primary" href="/resume/Vinay_Reddy_Resume.pdf" download><Download size={18} />Download Resume</a>
        <a class="button button-quiet" href="#projects"><ArrowDown size={18} />View Projects</a>
        <a class="button button-quiet" href="#contact"><Mail size={18} />Contact Me</a>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="chip" href="https://github.com/vinayace" target="_blank" rel="noreferrer"><CodeXml class="mr-2" size={15} />github.com/vinayace</a>
        <a class="chip" href="https://linkedin.com/in/vinay-reddy-2b44a4144" target="_blank" rel="noreferrer"><BriefcaseBusiness class="mr-2" size={15} />LinkedIn</a>
        <a class="chip" href="mailto:vinayreddy.ace@gmail.com"><Mail class="mr-2" size={15} />vinayreddy.ace@gmail.com</a>
        <a class="chip" href="tel:+919513368689"><Phone class="mr-2" size={15} />+91-9513368689</a>
      </div>
    </div>

    <div class="surface reveal rounded-lg p-5">
      <div class="grid gap-3">
        {[
          ["11+ years", "Mobile, AI, full-stack, and architecture delivery"],
          ["Banking Security SDKs", "Call blocking, SMS filtering, browser threat prevention"],
          ["Healthcare scale", "Sydney Health and large enterprise release ownership"],
          ["Applied AI", "GenAI decisioning, ML risk scoring, RAG, and agentic AI"]
        ].map(([metric, label]) => (
          <div class="rounded-md border border-white/10 bg-white/[0.045] p-4">
            <p class="font-display text-2xl font-extrabold">{metric}</p>
            <p class="mt-1 text-sm leading-6 text-[color:var(--muted)]">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
