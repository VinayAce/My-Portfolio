---
const capabilities = [
  {
    title: "Mobile Engineering",
    copy: "Core strength across native and cross-platform product delivery, SDK development, mobile architecture, and release quality.",
    skills: ["iOS", "Swift", "Objective-C", "Flutter", "Android", "React Native", "SDK Development", "Mobile Architecture"]
  },
  {
    title: "Full Stack & Backend",
    copy: "Product-facing backend ownership with API design, service integration, and modern web/mobile communication patterns.",
    skills: ["Next.js", "Node.js", "Express.js", "REST APIs", "FastAPI", "Python", "MongoDB", "SQL", "GraphQL", "Swagger", "Postman"]
  },
  {
    title: "Applied AI / GenAI",
    copy: "Practical AI services built around LLM integration, rule-assisted reasoning, retrieval concepts, and structured product outputs.",
    skills: ["Python", "Generative AI", "LLMs", "Gemini", "OpenAI API", "Prompt Engineering", "RAG", "AI Agents", "LangChain", "FAISS", "Scikit-learn", "XGBoost", "TensorFlow", "PyTorch"]
  },
  {
    title: "Architecture & System Design",
    copy: "Senior-level ownership of maintainable systems, modular codebases, scalable API contracts, and performance-focused engineering.",
    skills: ["System Design", "Technical Architecture", "Solution Architecture", "Clean Architecture", "MVC", "MVVM", "SOLID", "API Design", "Performance Optimization"]
  },
  {
    title: "Cloud / DevOps",
    copy: "Release-aware engineering across CI/CD, observability, cloud services, and mobile product delivery pipelines.",
    skills: ["Git", "GitHub Actions", "Bitrise", "Docker", "AWS Lambda", "S3", "EC2", "Firebase", "Crashlytics", "CI/CD"]
  },
  {
    title: "Leadership & Product Engineering",
    copy: "Technical leadership across sprint planning, mentoring, stakeholder alignment, roadmap estimation, and production readiness.",
    skills: ["Leadership", "Technical Architect", "Solution Architect", "Agile/Scrum", "Jira", "Story Estimation", "Release Planning", "Mentoring", "AI Product Thinking"]
  }
];
---

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  {capabilities.map((item) => (
    <article class="surface reveal rounded-lg p-6">
      <h3 class="font-display text-xl font-extrabold">{item.title}</h3>
      <p class="mt-3 min-h-24 text-sm leading-7 text-[color:var(--muted)]">{item.copy}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {item.skills.map((skill) => <span class="chip">{skill}</span>)}
      </div>
    </article>
  ))}
</div>
