---
import { Download, FileText } from "@lucide/astro";
---

<section id="resume" class="section">
  <div class="container">
    <div class="surface reveal rounded-lg p-8 md:p-10">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="eyebrow">Resume</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold md:text-4xl">A concise view of mobile, full-stack, AI, and leadership impact.</h2>
          <p class="mt-4 max-w-2xl leading-8 text-[color:var(--muted)]">
            Download the latest resume for detailed experience, technology stack, project history, and applied AI engineering work.
          </p>
        </div>
        <a class="button button-primary" href="/resume/Vinay_Reddy_Resume.pdf" download><FileText size={18} /><span>Download PDF</span><Download size={18} /></a>
      </div>
    </div>
  </div>
</section>
