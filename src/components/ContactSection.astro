---
import { BriefcaseBusiness, CodeXml, Mail, Phone } from "@lucide/astro";
---

<section id="contact" class="section">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center reveal">
      <p class="eyebrow">Contact</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold md:text-5xl">Open to strong engineering and AI leadership opportunities.</h2>
      <p class="mt-4 text-lg leading-8 text-[color:var(--muted)]">
        Best fit: technical lead, principal engineer, mobile platform, full-stack product engineering, applied AI, GenAI, and architecture roles.
      </p>
    </div>
    <div class="mx-auto mt-10 grid max-w-4xl gap-4 sm:grid-cols-2">
      <a class="surface reveal rounded-lg p-5 transition hover:border-[color:var(--accent)]" href="mailto:vinayreddy.ace@gmail.com"><Mail class="mb-4 text-[color:var(--accent)]" size={24} /><span class="block font-bold">Email</span><span class="mt-1 block text-sm text-[color:var(--muted)]">vinayreddy.ace@gmail.com</span></a>
      <a class="surface reveal rounded-lg p-5 transition hover:border-[color:var(--accent)]" href="tel:+919513368689"><Phone class="mb-4 text-[color:var(--accent)]" size={24} /><span class="block font-bold">Phone</span><span class="mt-1 block text-sm text-[color:var(--muted)]">+91-9513368689</span></a>
      <a class="surface reveal rounded-lg p-5 transition hover:border-[color:var(--accent)]" href="https://github.com/vinayace" target="_blank" rel="noreferrer"><CodeXml class="mb-4 text-[color:var(--accent)]" size={24} /><span class="block font-bold">GitHub</span><span class="mt-1 block text-sm text-[color:var(--muted)]">github.com/vinayace</span></a>
      <a class="surface reveal rounded-lg p-5 transition hover:border-[color:var(--accent)]" href="https://linkedin.com/in/vinay-reddy-2b44a4144" target="_blank" rel="noreferrer"><BriefcaseBusiness class="mb-4 text-[color:var(--accent)]" size={24} /><span class="block font-bold">LinkedIn</span><span class="mt-1 block text-sm text-[color:var(--muted)]">linkedin.com/in/vinay-reddy-2b44a4144</span></a>
    </div>
  </div>
</section>
